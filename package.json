{
  "name": "n8n-nodes-chainalysis",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Chainalysis blockchain analytics providing 23 resources and 250+ operations for address screening, transaction monitoring, sanctions checking, risk assessment, KYT compliance, and Reactor investigations.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-chainalysis.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-chainalysis#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-chainalysis/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "chainalysis",
    "blockchain",
    "analytics",
    "compliance",
    "kyc",
    "kyt",
    "aml",
    "sanctions",
    "risk-assessment",
    "cryptocurrency",
    "ofac",
    "reactor",
    "address-screening",
    "transaction-monitoring"
  ],
  "main": "dist/nodes/Chainalysis/Chainalysis.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ChainalysisApi.credentials.js",
      "dist/credentials/ChainalysisKyt.credentials.js",
      "dist/credentials/ChainalysisReactor.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Chainalysis/Chainalysis.node.js",
      "dist/nodes/Chainalysis/ChainalysisTrigger.node.js"
    ]
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "uuid": "^9.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-n8n-nodes-base": "^1.0.0",
    "gulp": "^4.0.2",
    "jest": "^29.0.0",
    "n8n-workflow": "*",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
